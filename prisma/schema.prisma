// School RBAC Platform — Prisma schema
// Postgres + Prisma. See docs/threat-model.md for the data-sensitivity notes.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; rhel-openssl-3.0.x is the Vercel serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app runtime (serverless); direct connection for
  // migrations (pgbouncer doesn't support the advisory locks Prisma needs).
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

// A tenant. All domain data is scoped to an organization.
model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  plan PlanTier @default(FREE)

  // Billing (wired to Stripe later — nullable now to avoid a future migration).
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  trialEndsAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  students        Student[]
  sessions        Session[]
  templates       SessionTemplate[]
  auditLogs       AuditLog[]
  todos           Todo[]
  oralAssessments OralAssessment[]
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  MANAGER
  SUPERVISOR
  TEACHER
}

model User {
  id             String  @id @default(cuid())
  organizationId String
  email          String  @unique
  passwordHash   String?
  name           String
  role           Role
  isActive       Boolean @default(true)

  // MFA (TOTP). mfaSecret is AES-256-GCM encrypted at the application layer.
  mfaSecret  String?
  mfaEnabled Boolean @default(false)

  // Session invalidation: bumping this version invalidates every issued JWT
  // (used on password change, role change, MFA reset, admin force-logout).
  tokenVersion Int @default(0)

  // Login throttling / lockout (per-account; per-IP handled via Redis).
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js adapter relations
  accounts     Account[]
  authSessions AuthSession[]

  // Domain relations
  sessions         Session[]           @relation("TeacherSessions")
  assignedSessions Session[]           @relation("AssignedByUser")
  assignedStudents StudentAssignment[]
  backupCodes      BackupCode[]
  auditLogs        AuditLog[]
  todos            Todo[]
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([role])
  @@index([organizationId])
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TodoPriority {
  NONE
  LOW
  MEDIUM
  HIGH
}

// Personal to-do items (private to each user).
model Todo {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  title          String
  notes          String?      @db.Text
  dueDate        DateTime?
  status         TodoStatus   @default(TODO)
  priority       TodoPriority @default(NONE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

// MFA backup codes (one-time use). Stored hashed (argon2), never in plaintext.
model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) adapter tables
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Database session store (fallback to JWT strategy; table kept for adapter).
model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Email magic-link & verification tokens. Token is stored HASHED (sha-256),
// single-use, short TTL — see lib/auth/tokens.ts.
model VerificationToken {
  identifier String
  token      String   @unique // sha-256 hash of the emailed token
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Students & records
// ---------------------------------------------------------------------------

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  SUSPENDED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
}

model Student {
  id             String        @id @default(cuid())
  organizationId String
  fullName       String
  externalId     String?
  gender         Gender?
  dateOfBirth    DateTime?
  placeOfBirth   String?
  // Parent / guardian contact phone number.
  parentPhone    String?
  // Cohort label (e.g. "Grade 6 (B)") — used by the statistical balance engine
  // to compare grading consistency across classrooms.
  classroom      String?
  status         StudentStatus @default(ACTIVE)
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  marks           Mark[]
  healthRecords   HealthRecord[]
  oralAssessments OralAssessment[]
  assignments     StudentAssignment[]
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalId])
  @@index([status])
  @@index([organizationId])
  @@index([classroom])
}

model StudentAssignment {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentId, teacherId])
  @@index([teacherId])
}

model Mark {
  id           String   @id @default(cuid())
  studentId    String
  subject      String
  score        Decimal  @db.Decimal(5, 2)
  maxScore     Decimal  @db.Decimal(5, 2)
  term         String
  recordedById String
  recordedAt   DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

enum HealthCategory {
  MENTAL
  PHYSICAL
}

model HealthRecord {
  id           String         @id @default(cuid())
  studentId    String
  category     HealthCategory
  summary      String
  // ENCRYPTED at the application layer (AES-256-GCM). Stores ciphertext bundle
  // "v1:<iv>:<authTag>:<ciphertext>" — see lib/security/crypto.ts.
  details      String?        @db.Text
  recordedById String
  recordedAt   DateTime       @default(now())
  student      Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Oral assessment — "Mizan Al-Farooq" criteria-based Qur'anic grading
// ---------------------------------------------------------------------------

// Four performance descriptors for each rubric criterion. Numeric weights
// (1..4) live in code (lib/assessment/rubric.ts), not the DB, so the rubric can
// be re-weighted without a migration.
enum RubricLevel {
  BEGINNER
  DEVELOPING
  COMPETENT
  DISTINGUISHED
}

// One criteria-based oral evaluation of a student (memorization + tajweed +
// articulation). The equivalent percentage `oralScore` is computed from the
// three rubric levels at write time so the dashboard's statistical engine can
// aggregate it cheaply. `writtenScore` is the matching written-theory result,
// used to detect grade inflation (high, uniform oral marks vs. variable written
// marks).
model OralAssessment {
  id             String      @id @default(cuid())
  organizationId String
  studentId      String
  // What was assessed, e.g. "Al-Mulk 1-10".
  surah          String
  hifz           RubricLevel
  tajweed        RubricLevel
  makharij       RubricLevel
  oralScore      Decimal     @db.Decimal(5, 2)
  writtenScore   Decimal?    @db.Decimal(5, 2)
  recordedById   String
  recordedAt     DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Sessions (lessons / appointments assigned to teachers)
// ---------------------------------------------------------------------------

enum SessionStatus {
  SCHEDULED
  TAKEN
  MISSED
  RESCHEDULED
  CANCELLED
}

model SessionTemplate {
  id              String       @id @default(cuid())
  organizationId  String
  type            String
  defaultDuration Int
  createdById     String
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
}

model Session {
  id             String        @id @default(cuid())
  organizationId String
  teacherId      String
  assignedById   String
  type           String
  scheduledAt    DateTime
  durationMin    Int
  status         SessionStatus @default(SCHEDULED)
  notes          String?       @db.Text
  takenAt        DateTime?
  teacher        User          @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  assignedBy     User          @relation("AssignedByUser", fields: [assignedById], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([teacherId])
  @@index([scheduledAt])
  @@index([status])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Audit log (append-only — UPDATE/DELETE revoked for app role via migration)
// ---------------------------------------------------------------------------

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String
  action         String
  entity         String
  entityId       String
  diff           Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  actor          User         @relation(fields: [actorId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([organizationId])
}
